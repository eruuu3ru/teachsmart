<%- include('partials/header') %>

<!-- Animated Background Blobs -->
<div class="bg-animated">
  <div class="bg-orb bg-orb-1"></div>
  <div class="bg-orb bg-orb-2"></div>
</div>

<div class="dashboard-page">
  <!-- Dashboard Header -->
  <div class="dashboard-header" style="display: flex; justify-content: space-between; align-items: flex-end; gap: 20px; flex-wrap: wrap;">
    <div>
      <p style="color: var(--color-highlight); font-weight: 600; text-transform: uppercase; letter-spacing: 1.5px; font-size: 0.8rem; margin-bottom: 4px;">Welcome Back</p>
      <h1><%= user.fullName %></h1>
      <p>Unique ID: <code style="background: rgba(255,255,255,0.04); padding: 2px 6px; border-radius: 4px; color: var(--color-accent);"><%= user.uniqueId %></code></p>
    </div>
    <div style="display: flex; gap: 10px;">
      <% if (user.role === 'admin') { %>
        <a href="/admin" class="btn btn-secondary btn-sm">Admin Panel</a>
      <% } %>
      <a href="/logout" class="btn btn-danger btn-sm">Logout</a>
    </div>
  </div>

  <!-- Pending Orders Alert/List -->
  <% if (pendingOrders && pendingOrders.length > 0) { %>
    <div class="pending-orders">
      <h3 style="font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 2px; color: var(--color-warning); margin-bottom: 1rem;">Awaiting Payment Verification</h3>
      <% pendingOrders.forEach(order => { %>
        <div class="pending-card">
          <div class="pending-info">
            <span class="pending-dot" style="width: 10px; height: 10px; border-radius: 50%; background: var(--color-warning); display: inline-block; animation: pulse 2s infinite;"></span>
            <div>
              <div class="pending-name"><%= order.product_name %></div>
              <div style="font-size: 0.75rem; color: var(--text-muted);">
                Reference: <code style="color: var(--text-secondary);"><%= order.payment_reference.split('|')[1] %></code>
              </div>
            </div>
          </div>
          <span class="badge badge-pending">Pending Verification</span>
        </div>
      <% }) %>
    </div>
  <% } %>

  <!-- Purchased Products (Library Content) -->
  <div style="margin-top: 3rem;">
    <% if (Object.keys(categories).length === 0) { %>
      <div class="glass-card" style="text-align: center; padding: 4rem 2rem; border-color: rgba(255, 255, 255, 0.05);">
        <div style="margin-bottom: 1.5rem;">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--text-muted);"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
        </div>
        <h2 style="font-size: 1.8rem; font-weight: 800; margin-bottom: 0.5rem;">Your Library is Empty</h2>
        <p style="color: var(--text-secondary); margin-bottom: 2rem; max-width: 450px; margin-left: auto; margin-right: auto;">
          You haven't unlocked any reviewer materials yet. Choose a subject to get started on your prep!
        </p>
        <a href="/register" class="btn btn-primary btn-lg">Browse & Unlock Reviewers</a>
      </div>
    <% } else { %>
      <h2 style="font-size: 1.25rem; font-weight: 800; margin-bottom: 1.5rem;">
        Your Library
      </h2>

      <% Object.keys(categories).forEach(category => { %>
        <div class="category-section">
          <h3 class="category-title"><%= category %></h3>
          <div class="subjects-grid">
            <% categories[category].forEach(product => { %>
              <a href="/reader/<%= product.id %>" class="subject-card" data-product-id="<%= product.id %>">
                <div class="card-top">
                  <div class="card-emoji" style="background: <%= product.category === 'LET Reviewer' ? 'rgba(255, 255, 255, 0.03)' : 'rgba(255, 255, 255, 0.05)' %>; border: 1px solid var(--border-color); border-radius: var(--radius-sm); font-size: 0.8rem; font-weight: 800; display: flex; align-items: center; justify-content: center; width: 42px; height: 42px; color: var(--text-primary); text-transform: uppercase; letter-spacing: 0.5px;">
                    <%= product.name.split(' ').map(w => w[0]).join('') %>
                  </div>
                  <div>
                    <h3 style="margin-bottom: 4px;"><%= product.name %></h3>
                    <div class="card-meta"><%= product.total_pages %> Chapters/Pages</div>
                  </div>
                </div>
                
                <p style="font-size: 0.85rem; color: var(--text-secondary); margin-bottom: 1.5rem; line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; text-overflow: ellipsis; min-height: 2.8rem;">
                  <%= product.description %>
                </p>

                <div class="card-progress">
                  <div class="progress-bar">
                    <div class="progress-fill" id="progress-fill-<%= product.id %>" style="width: 0%"></div>
                  </div>
                  <div style="display: flex; justify-content: space-between; font-size: 0.75rem; color: var(--text-muted); margin-top: 6px;">
                    <span>Read Progress</span>
                    <span id="progress-text-<%= product.id %>">0%</span>
                  </div>
                </div>
                
                <div class="btn btn-secondary btn-sm btn-block" style="margin-top: 1rem; border-color: rgba(255,255,255,0.05);">
                  Open Material
                </div>
              </a>
            <% }) %>
          </div>
        </div>
      <% }) %>
    <% } %>
  </div>
</div>

<%- include('partials/footer') %>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Dynamic progress calculation using localStorage
    const userId = '<%= user.userId || user.id %>';
    document.querySelectorAll('.subject-card').forEach(card => {
      const productId = card.getAttribute('data-product-id');
      const progressKey = `tsa_progress_${userId}_${productId}`;
      const savedProgress = localStorage.getItem(progressKey);
      if (savedProgress) {
        try {
          const { page, total } = JSON.parse(savedProgress);
          if (page && total) {
            const percent = Math.min(100, Math.round((page / total) * 100));
            const fill = document.getElementById(`progress-fill-${productId}`);
            const text = document.getElementById(`progress-text-${productId}`);
            if (fill) fill.style.width = `${percent}%`;
            if (text) text.innerText = `${percent}%`;
          }
        } catch (e) {
          console.error('Error loading progress:', e);
        }
      }
    });
  });
</script>
