<%- include('../partials/header') %>

<div class="bg-animated">
  <div class="bg-orb bg-orb-1"></div>
  <div class="bg-orb bg-orb-2"></div>
</div>

<div class="admin-page">
  <!-- Header -->
  <div class="dashboard-header" style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 2rem; flex-wrap: wrap; gap: 20px;">
    <div>
      <h1 style="margin: 0;">Manage Orders</h1>
    </div>
    <div>
      <a href="/admin" class="btn btn-secondary btn-sm">← Back Overview</a>
    </div>
  </div>

  <!-- Admin Sub Navigation Tabs -->
  <div class="filter-tabs" style="margin-bottom: 2rem;">
    <a href="/admin" class="filter-tab">Overview</a>
    <a href="/admin/orders" class="filter-tab active">Orders</a>
    <a href="/admin/users" class="filter-tab">Users</a>
    <a href="/admin/content" class="filter-tab">Content</a>
    <a href="/admin/coupons" class="filter-tab">Coupons</a>
    <a href="/admin/alerts" class="filter-tab">Alerts</a>
  </div>

  <!-- Filters Row -->
  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; flex-wrap: wrap; gap: 15px;">
    <div style="display: flex; gap: 8px;">
      <a href="/admin/orders?filter=all" class="btn btn-secondary btn-sm <%= filter === 'all' ? 'active' : '' %>" style="border-radius: var(--radius-full);">All</a>
      <a href="/admin/orders?filter=pending" class="btn btn-secondary btn-sm <%= filter === 'pending' ? 'active' : '' %>" style="border-radius: var(--radius-full); border-color: rgba(255, 181, 71, 0.3);">Pending</a>
      <a href="/admin/orders?filter=verified" class="btn btn-secondary btn-sm <%= filter === 'verified' ? 'active' : '' %>" style="border-radius: var(--radius-full); border-color: rgba(0, 224, 168, 0.3);">Verified</a>
      <a href="/admin/orders?filter=rejected" class="btn btn-secondary btn-sm <%= filter === 'rejected' ? 'active' : '' %>" style="border-radius: var(--radius-full); border-color: rgba(255, 71, 87, 0.3);">Rejected</a>
    </div>
    <div style="font-size: 0.85rem; color: var(--text-secondary);">
      Showing <strong><%= transactions.length %></strong> transactions(s)
    </div>
  </div>

  <!-- Transactions List -->
  <div style="display: flex; flex-direction: column; gap: 24px;">
    <% if (transactions.length === 0) { %>
      <div class="glass-card" style="text-align: center; padding: 4rem 0; color: var(--text-muted);">
        <div style="margin-bottom: 1.5rem;">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--text-muted);"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
        </div>
        <p>No orders found matching the chosen criteria.</p>
      </div>
    <% } else { %>
      <% transactions.forEach(txn => { %>
        <div class="glass-card transaction-card" id="txn-card-<%= txn.txnId.replace(/[^a-zA-Z0-9]/g, '-') %>" style="padding: 0; overflow: hidden; border-color: rgba(255, 255, 255, 0.04); transition: all 0.3s ease;">
          <!-- Card Top Bar -->
          <div style="background: rgba(255, 255, 255, 0.015); border-bottom: 1px solid var(--border-color); padding: 16px 24px; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 10px;">
            <div style="display: flex; align-items: center; gap: 12px;">
              <span style="font-size: 0.8rem; text-transform: uppercase; color: var(--text-muted); font-weight: bold; letter-spacing: 0.5px;">Order Reference:</span>
              <code style="font-size: 0.95rem; color: var(--color-accent); font-weight: bold; background: rgba(255,255,255,0.03); padding: 4px 8px; border-radius: 6px;"><%= txn.txnId %></code>
            </div>
            <div style="display: flex; align-items: center; gap: 15px;">
              <span style="font-size: 0.82rem; color: var(--text-muted);">
                <%= new Date(txn.createdAt).toLocaleString([], { dateStyle: 'medium', timeStyle: 'short' }) %>
              </span>
              <span class="badge badge-<%= txn.status %> status-badge"><%= txn.status %></span>
              <button class="btn btn-danger btn-sm delete-txn-btn" data-txn="<%= txn.txnId %>" style="padding: 4px 8px; font-size: 0.75rem; min-width: auto; border-color: rgba(255,255,255,0.05);" title="Delete Transaction Log">Delete</button>
            </div>
          </div>

          <!-- Card Content Body -->
          <div style="padding: 24px; display: grid; grid-template-columns: 1.2fr 1.8fr; gap: 30px;" class="txn-card-grid">
            <!-- Left Side: Buyer & Payment Info -->
            <div style="border-right: 1px solid var(--border-color); padding-right: 20px;" class="buyer-info-col">
              <h4 style="margin-top: 0; margin-bottom: 12px; font-size: 0.9rem; text-transform: uppercase; letter-spacing: 1px; color: var(--text-secondary);">Customer Profile</h4>
              <div style="margin-bottom: 16px;">
                <strong style="font-size: 1.05rem; color: var(--text-primary);"><%= txn.fullName %></strong><br>
                <span style="font-size: 0.85rem; color: var(--text-secondary);"><%= txn.email %></span><br>
                <span style="font-size: 0.85rem; color: var(--text-muted);"><%= txn.phone || 'No phone number' %></span>
              </div>

              <h4 style="margin-bottom: 8px; font-size: 0.9rem; text-transform: uppercase; letter-spacing: 1px; color: var(--text-secondary);">Payment Source</h4>
              <div>
                <strong style="text-transform: uppercase; font-size: 0.85rem; color: var(--color-accent); display: block; margin-bottom: 2px;"><%= txn.paymentMethod %></strong>
                <span style="font-size: 0.8rem; color: var(--text-secondary);">Reference ID: <code><%= txn.paymentRef %></code></span>
              </div>
            </div>

            <!-- Right Side: Purchased items -->
            <div>
              <h4 style="margin-top: 0; margin-bottom: 12px; font-size: 0.9rem; text-transform: uppercase; letter-spacing: 1px; color: var(--text-secondary);">Purchased Reviewers</h4>
              <div style="display: flex; flex-direction: column; gap: 12px;">
                <% txn.items.forEach(item => { %>
                  <div style="background: rgba(255, 255, 255, 0.01); border: 1px solid var(--border-color); border-radius: 8px; padding: 12px 16px; display: flex; justify-content: space-between; align-items: center;">
                    <div>
                      <span class="badge" style="background: rgba(255, 255, 255, 0.04); color: var(--text-secondary); font-size: 0.68rem; padding: 2px 6px; margin-bottom: 4px; display: inline-block;"><%= item.category %></span>
                      <div style="font-weight: 600; font-size: 0.95rem; color: var(--text-primary);"><%= item.productName %></div>
                    </div>
                    <div style="text-align: right;">
                      <div style="font-weight: 700; color: var(--text-primary); font-size: 0.95rem;">₱<%= item.price.toFixed(2) %></div>
                      <span class="badge badge-<%= item.status %>" style="font-size: 0.65rem; padding: 2px 6px;"><%= item.status %></span>
                    </div>
                  </div>
                <% }) %>
              </div>
            </div>
          </div>

          <!-- Card Bottom Bar (Actions & Total) -->
          <div style="background: rgba(255, 255, 255, 0.005); border-top: 1px solid var(--border-color); padding: 16px 24px; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 15px;">
            <div>
              <span style="font-size: 0.85rem; color: var(--text-muted);">Total Transaction Value:</span>
              <span style="font-size: 1.3rem; font-weight: 800; color: var(--text-primary); margin-left: 8px;">₱<%= txn.total.toFixed(2) %></span>
            </div>
            
            <div class="action-buttons-wrapper">
              <% if (txn.status === 'pending') { %>
                <div style="display: flex; gap: 10px;" class="action-btn-group">
                  <button class="btn btn-success btn-sm approve-txn-btn" data-txn="<%= txn.txnId %>" data-ref="<%= txn.paymentRef %>" style="padding: 8px 18px; font-weight: 600;">
                    Approve Payment
                  </button>
                  <button class="btn btn-danger btn-sm reject-txn-btn" data-txn="<%= txn.txnId %>" style="padding: 8px 18px; font-weight: 600;">
                    Reject Submission
                  </button>
                </div>
              <% } else if (txn.status === 'verified') { %>
                <div style="display: flex; flex-direction: column; gap: 8px;">
                  <span style="color: var(--color-success); font-weight: 700; display: inline-flex; align-items: center; gap: 6px; font-size: 0.9rem;">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                    Verified & Account Activated
                  </span>
                  <div class="creds-inline" style="display: flex; gap: 12px; flex-wrap: wrap; font-size: 0.8rem; background: rgba(0,0,0,0.2); padding: 8px 12px; border-radius: 6px; border: 1px solid rgba(0,224,168,0.15);">
                    <span><strong style="color: var(--text-muted);">Unique ID:</strong> <code class="creds-uniqueid" style="color: var(--color-accent);"><%= txn.uniqueId || '' %></code></span>
                    <span><strong style="color: var(--text-muted);">Password:</strong> <code class="creds-password" style="color: #fff;"><%= txn.plainPassword || '********' %></code> <button type="button" class="toggle-pwd-btn" onclick="togglePwd(this)" style="background:none;border:none;cursor:pointer;color:#9CA3AF;padding:2px 4px;vertical-align:middle;" title="Show/hide password"><% if (txn.plainPassword) { %><svg class="eye-off-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg><% } else { %><svg class="eye-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg><% } %></button></span>
                  </div>
                </div>
              <% } else { %>
                <span style="color: var(--color-danger); font-weight: 700; display: inline-flex; align-items: center; gap: 6px; font-size: 0.9rem;">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                  Payment Rejected
                </span>
              <% } %>
            </div>
          </div>
        </div>
      <% }) %>
    <% } %>
  </div>
</div>

<!-- Modal Container for Verification Credentials -->
<div id="credentials-modal" class="modal-overlay" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.7); backdrop-filter: blur(8px); z-index: 10000; align-items: center; justify-content: center;">
  <div class="glass-card" style="width: 90%; max-width: 500px; padding: 2rem; border-color: rgba(255,255,255,0.08); box-shadow: 0 24px 48px rgba(0,0,0,0.5);">
    <h3 style="margin-top: 0; margin-bottom: 10px; font-size: 1.3rem; display: flex; align-items: center; gap: 10px;">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-success)" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
      Payment Verified Successfully
    </h3>
    <p style="font-size: 0.85rem; color: var(--text-secondary); margin-bottom: 1.5rem;">
      The payment reference is confirmed. The student's account is now active. Copy credentials to share if needed.
    </p>

    <div style="background: rgba(0, 0, 0, 0.25); border: 1px solid var(--border-color); border-radius: 8px; padding: 16px; margin-bottom: 1.5rem;" id="modal-credentials-box">
      <div class="cred-item" style="display: flex; justify-content: space-between; margin-bottom: 10px;">
        <span class="cred-label" style="color: var(--text-muted); font-size: 0.85rem;">Name:</span>
        <strong class="cred-value" id="modal-fullName" style="color: white;">-</strong>
      </div>
      <div class="cred-item" style="display: flex; justify-content: space-between; margin-bottom: 10px;">
        <span class="cred-label" style="color: var(--text-muted); font-size: 0.85rem;">Email:</span>
        <strong class="cred-value" id="modal-email" style="color: white;">-</strong>
      </div>
      <div class="cred-item" style="display: flex; justify-content: space-between; margin-bottom: 10px; align-items: center;">
        <span class="cred-label" style="color: var(--text-muted); font-size: 0.85rem;">Unique ID (User ID):</span>
        <code id="modal-uniqueId" style="background: var(--bg-primary); padding: 4px 8px; border-radius: 4px; color: var(--color-accent); font-size: 0.9rem; font-weight: bold;">-</code>
      </div>
      <div class="cred-item" style="display: flex; justify-content: space-between; align-items: center;">
        <span class="cred-label" style="color: var(--text-muted); font-size: 0.85rem;">Generated Password:</span>
        <code id="modal-password" style="background: var(--bg-primary); padding: 4px 8px; border-radius: 4px; color: white; font-size: 0.9rem; font-weight: bold;">-</code>
        <button type="button" onclick="toggleModalPwd()" style="background:none;border:none;cursor:pointer;color:#9CA3AF;padding:2px 4px;vertical-align:middle;margin-left:4px;" title="Show/hide password"><svg class="eye-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg></button>
      </div>
    </div>

    <div style="display: flex; gap: 12px; justify-content: flex-end;">
      <button id="copy-modal-creds" class="btn btn-primary" style="padding: 8px 18px; font-size: 0.85rem;">
        Copy All Credentials
      </button>
      <button id="close-modal-creds" class="btn btn-secondary" style="padding: 8px 18px; font-size: 0.85rem;">
        Close
      </button>
    </div>
  </div>
</div>

<!-- Toast Notification Container -->
<div id="toast-container" style="position:fixed;top:80px;left:50%;transform:translateX(-50%);z-index:99999;display:flex;flex-direction:column;gap:10px;pointer-events:none;"></div>

<!-- Confirmation Modal -->
<div id="confirm-modal" class="modal-overlay" style="display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.6);backdrop-filter:blur(6px);z-index:99998;align-items:center;justify-content:center;">
  <div class="glass-card" style="width:90%;max-width:440px;padding:2rem;border-color:rgba(255,255,255,0.08);box-shadow:0 24px 48px rgba(0,0,0,0.5);text-align:center;animation:confirmFadeIn 0.2s ease-out;">
    <div id="confirm-icon" style="margin-bottom:1rem;"></div>
    <h3 id="confirm-title" style="margin:0 0 8px;font-size:1.2rem;"></h3>
    <p id="confirm-message" style="font-size:0.85rem;color:var(--text-secondary);margin-bottom:1.5rem;"></p>
    <div style="display:flex;gap:12px;justify-content:center;">
      <button id="confirm-cancel-btn" class="btn btn-secondary" style="padding:8px 20px;font-size:0.85rem;">Cancel</button>
      <button id="confirm-ok-btn" class="btn btn-primary" style="padding:8px 20px;font-size:0.85rem;">Confirm</button>
    </div>
  </div>
</div>

<style>
  #toast-container > .toast-item {
    pointer-events: auto;
    padding: 14px 24px;
    border-radius: 12px;
    background: rgba(20,20,22,0.95);
    border: 1px solid rgba(255,255,255,0.08);
    box-shadow: 0 12px 40px rgba(0,0,0,0.5);
    color: #fff;
    font-size: 0.85rem;
    font-weight: 500;
    display: flex;
    align-items: center;
    gap: 10px;
    animation: toastSlideIn 0.25s ease-out;
    min-width: 280px;
    max-width: 500px;
    backdrop-filter: blur(12px);
  }
  #toast-container > .toast-item.toast-hide {
    animation: toastFadeOut 0.2s ease-in forwards;
  }
  #toast-container > .toast-item.toast-success { border-left: 3px solid var(--color-success); }
  #toast-container > .toast-item.toast-error { border-left: 3px solid var(--color-danger); }
  #toast-container > .toast-item.toast-warning { border-left: 3px solid var(--color-warning); }
  #toast-container > .toast-item.toast-info { border-left: 3px solid var(--color-accent); }
  @keyframes toastSlideIn {
    from { opacity: 0; transform: translateY(-20px) scale(0.95); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }
  @keyframes toastFadeOut {
    from { opacity: 1; transform: translateY(0) scale(1); }
    to { opacity: 0; transform: translateY(-20px) scale(0.95); }
  }
  @keyframes confirmFadeIn {
    from { opacity: 0; transform: scale(0.92); }
    to { opacity: 1; transform: scale(1); }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const modal = document.getElementById('credentials-modal');
    const closeBtn = document.getElementById('close-modal-creds');
    const copyBtn = document.getElementById('copy-modal-creds');

    let currentCreds = null;

    closeBtn.addEventListener('click', () => {
      modal.style.display = 'none';
    });

    copyBtn.addEventListener('click', () => {
      if (!currentCreds) return;
      const textToCopy = `TeachSmart Academy Credentials\n---------------------------\nName: ${currentCreds.fullName}\nEmail: ${currentCreds.email}\nUnique ID: ${currentCreds.uniqueId}\nPassword: ${currentCreds.password}`;
      navigator.clipboard.writeText(textToCopy).then(() => {
        const originalText = copyBtn.textContent;
        copyBtn.textContent = 'Copied!';
        copyBtn.style.background = 'var(--color-success)';
        setTimeout(() => {
          copyBtn.textContent = originalText;
          copyBtn.style.background = '';
        }, 1500);
      });
    });

    // Handle AJAX batch verification
    const approveButtons = document.querySelectorAll('.approve-txn-btn');
    approveButtons.forEach(btn => {
      btn.addEventListener('click', async (e) => {
        e.preventDefault();
        const txnId = btn.getAttribute('data-txn');
        const refId = btn.getAttribute('data-ref');

        showConfirm(`Verify payment for transaction ${txnId} (Reference ID: ${refId})?`, 'Confirm Verify', async () => {
          btn.disabled = true;
          btn.textContent = 'Verifying...';

          try {
            const res = await fetch(`/admin/orders/transaction/${encodeURIComponent(txnId)}/verify`, {
              method: 'POST',
              headers: {
                'Accept': 'application/json',
                'X-Requested-With': 'XMLHttpRequest'
              }
            });

            const data = await res.json();
            if (data.success) {
              const cardId = 'txn-card-' + txnId.replace(/[^a-zA-Z0-9]/g, '-');
              const card = document.getElementById(cardId);
              if (card) {
                const badge = card.querySelector('.status-badge');
                if (badge) {
                  badge.className = 'badge badge-verified status-badge';
                  badge.textContent = 'verified';
                }

                const productBadges = card.querySelectorAll('.badge-pending');
                productBadges.forEach(b => {
                  b.className = 'badge badge-verified';
                  b.textContent = 'verified';
                });

                const wrapper = card.querySelector('.action-buttons-wrapper');
                if (wrapper) {
                  wrapper.innerHTML = `
                    <div style="display: flex; flex-direction: column; gap: 8px;">
                      <span style="color: var(--color-success); font-weight: 700; display: inline-flex; align-items: center; gap: 6px; font-size: 0.9rem;">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                        Verified & Account Activated
                      </span>
                      <div class="creds-inline" style="display: flex; gap: 12px; flex-wrap: wrap; font-size: 0.8rem; background: rgba(0,0,0,0.2); padding: 8px 12px; border-radius: 6px; border: 1px solid rgba(0,224,168,0.15);">
                        <span><strong style="color: var(--text-muted);">Unique ID:</strong> <code class="creds-uniqueid" style="color: var(--color-accent);">${data.credentials.uniqueId}</code></span>
                        <span><strong style="color: var(--text-muted);">Password:</strong> <code class="creds-password" style="color: #fff;">${data.credentials.password}</code> <button type="button" class="toggle-pwd-btn" onclick="togglePwd(this)" style="background:none;border:none;cursor:pointer;color:#9CA3AF;padding:2px 4px;vertical-align:middle;" title="Show/hide password"><svg class="eye-off-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg></button></span>
                      </div>
                    </div>
                  `;
                }
              }

              currentCreds = data.credentials;
              document.getElementById('modal-fullName').textContent = currentCreds.fullName;
              document.getElementById('modal-email').textContent = currentCreds.email;
              document.getElementById('modal-uniqueId').textContent = currentCreds.uniqueId;
              document.getElementById('modal-password').textContent = currentCreds.password;

              modal.style.display = 'flex';
              showToast('Payment verified successfully', 'success');
            } else {
              showToast('Verification failed: ' + (data.error || 'Unknown error'), 'error');
              btn.disabled = false;
              btn.textContent = 'Approve Payment';
            }
          } catch (err) {
            console.error('Verify error:', err);
            showToast('An error occurred during verification.', 'error');
            btn.disabled = false;
            btn.textContent = 'Approve Payment';
          }
        }, 'success');
      });
    });

    // Handle AJAX batch rejection
    const rejectButtons = document.querySelectorAll('.reject-txn-btn');
    rejectButtons.forEach(btn => {
      btn.addEventListener('click', async (e) => {
        e.preventDefault();
        const txnId = btn.getAttribute('data-txn');

        showConfirm(`Reject payment and deny access for transaction ${txnId}?`, 'Reject', async () => {
          btn.disabled = true;
          btn.textContent = 'Rejecting...';

          try {
            const res = await fetch(`/admin/orders/transaction/${encodeURIComponent(txnId)}/reject`, {
              method: 'POST',
              headers: {
                'Accept': 'application/json',
                'X-Requested-With': 'XMLHttpRequest'
              }
            });

            const data = await res.json();
            if (data.success) {
              const cardId = 'txn-card-' + txnId.replace(/[^a-zA-Z0-9]/g, '-');
              const card = document.getElementById(cardId);
              if (card) {
                const badge = card.querySelector('.status-badge');
                if (badge) {
                  badge.className = 'badge badge-rejected status-badge';
                  badge.textContent = 'rejected';
                }

                const productBadges = card.querySelectorAll('.badge-pending');
                productBadges.forEach(b => {
                  b.className = 'badge badge-rejected';
                  b.textContent = 'rejected';
                });

                const wrapper = card.querySelector('.action-buttons-wrapper');
                if (wrapper) {
                  wrapper.innerHTML = `
                    <span style="color: var(--color-danger); font-weight: 700; display: inline-flex; align-items: center; gap: 6px; font-size: 0.9rem;">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                      Payment Rejected
                    </span>
                  `;
                }
              }
              showToast('Payment rejected successfully', 'warning');
            } else {
              showToast('Rejection failed: ' + (data.error || 'Unknown error'), 'error');
              btn.disabled = false;
              btn.textContent = 'Reject Submission';
            }
          } catch (err) {
            console.error('Reject error:', err);
            showToast('An error occurred during rejection.', 'error');
            btn.disabled = false;
            btn.textContent = 'Reject Submission';
          }
        });
      });
    });

    // Handle AJAX transaction deletion
    const deleteButtons = document.querySelectorAll('.delete-txn-btn');
    deleteButtons.forEach(btn => {
      btn.addEventListener('click', async (e) => {
        e.preventDefault();
        const txnId = btn.getAttribute('data-txn');

        showConfirm(`Permanently delete transaction ${txnId}? This will remove it from the dashboard completely.`, 'Delete', async () => {
          btn.disabled = true;
          try {
            const res = await fetch(`/admin/orders/transaction/${encodeURIComponent(txnId)}/delete`, {
              method: 'POST',
              headers: {
                'Accept': 'application/json',
                'X-Requested-With': 'XMLHttpRequest'
              }
            });

            const data = await res.json();
            if (data.success) {
              const cardId = 'txn-card-' + txnId.replace(/[^a-zA-Z0-9]/g, '-');
              const card = document.getElementById(cardId);
              if (card) {
                card.style.opacity = '0';
                card.style.transform = 'translateY(20px)';
                setTimeout(() => {
                  card.remove();
                  if (document.querySelectorAll('.transaction-card').length === 0) {
                    window.location.reload();
                  }
                }, 300);
              }
              showToast('Transaction deleted successfully', 'success');
            } else {
              showToast('Delete failed: ' + (data.error || 'Unknown error'), 'error');
              btn.disabled = false;
            }
          } catch (err) {
            console.error('Delete error:', err);
            showToast('An error occurred during deletion.', 'error');
            btn.disabled = false;
          }
        });
      });
    });
  });

  function toggleModalPwd() {
    const code = document.getElementById('modal-password');
    const btn = code.nextElementSibling;
    if (!code.dataset.real || code.dataset.real === '-' || code.dataset.real === '********') {
      if (typeof currentCreds !== 'undefined' && currentCreds && currentCreds.password) {
        code.dataset.real = currentCreds.password;
      } else {
        code.dataset.real = code.textContent;
      }
    }
    const real = code.dataset.real;
    if (real === '-' || real === '********') return;
    const eyeOn = '<svg class="eye-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>';
    const eyeOff = '<svg class="eye-off-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>';
    if (code.textContent === '********') {
      code.textContent = real;
      btn.innerHTML = eyeOff;
    } else {
      code.textContent = '********';
      btn.innerHTML = eyeOn;
    }
  }

  function togglePwd(btn) {
    const code = btn.previousElementSibling;
    if (!code.dataset.real || code.dataset.real === '********') {
      if (typeof currentCreds !== 'undefined' && currentCreds && currentCreds.password) {
        code.dataset.real = currentCreds.password;
      } else {
        code.dataset.real = code.textContent;
      }
    }
    if (code.dataset.real === '********' || code.dataset.real === '-') return;
    const eyeOn = '<svg class="eye-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>';
    const eyeOff = '<svg class="eye-off-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>';
    if (code.textContent === '********') {
      code.textContent = code.dataset.real;
      btn.innerHTML = eyeOff;
    } else {
      code.textContent = '********';
      btn.innerHTML = eyeOn;
    }
  }

  function showToast(message, type) {
    type = type || 'info';
    const container = document.getElementById('toast-container');
    const icons = {
      success: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-success)" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>',
      error: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-danger)" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>',
      warning: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-warning)" stroke-width="2.5"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>',
      info: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2.5"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>'
    };
    const el = document.createElement('div');
    el.className = 'toast-item toast-' + type;
    el.innerHTML = (icons[type] || icons.info) + '<span>' + message + '</span>';
    container.appendChild(el);
    setTimeout(() => {
      el.classList.add('toast-hide');
      setTimeout(() => el.remove(), 200);
    }, 3500);
  }

  function showConfirm(message, title, onConfirm, type) {
    type = type || 'danger';
    const modal = document.getElementById('confirm-modal');
    document.getElementById('confirm-title').textContent = title || 'Confirm';
    document.getElementById('confirm-message').textContent = message;
    const iconMap = {
      'Confirm Verify': '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--color-success)" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline><circle cx="12" cy="12" r="10"/></svg>',
      'Delete': '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--color-danger)" stroke-width="2"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>',
      'Reject': '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--color-warning)" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="15" y1="9" x2="9" y2="15"></line><line x1="9" y1="9" x2="15" y2="15"></line></svg>',
      'Warning': '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--color-warning)" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>'
    };
    const iconSvg = iconMap[title] || iconMap['Warning'];
    document.getElementById('confirm-icon').innerHTML = iconSvg;
    const okBtn = document.getElementById('confirm-ok-btn');
    const cancelBtn = document.getElementById('confirm-cancel-btn');
    okBtn.className = 'btn btn-' + (type === 'success' ? 'primary' : 'danger');
    okBtn.textContent = title || 'Confirm';
    modal.style.display = 'flex';
    const cleanup = () => {
      modal.style.display = 'none';
      okBtn.removeEventListener('click', handleOk);
      cancelBtn.removeEventListener('click', cleanup);
      modal.removeEventListener('click', outsideClick);
    };
    const handleOk = () => { cleanup(); if (onConfirm) onConfirm(); };
    const outsideClick = (e) => { if (e.target === modal) cleanup(); };
    okBtn.onclick = handleOk;
    cancelBtn.onclick = cleanup;
    modal.onclick = outsideClick;
  }
</script>

