<%- include('partials/header') %>

<div class="bg-animated">
  <div class="bg-orb bg-orb-1" style="background: var(--color-danger); opacity: 0.1;"></div>
  <div class="bg-orb bg-orb-2" style="background: var(--color-warning); opacity: 0.1;"></div>
</div>

<div class="form-page">
  <div class="form-container">
    <div class="form-card" style="text-align: center; border-color: rgba(255, 255, 255, 0.05);">
      
      <!-- Dynamic Icon based on Error Title -->
      <div style="margin-bottom: 1.5rem; display: flex; justify-content: center; filter: drop-shadow(0 0 15px rgba(255, 255, 255, 0.1));">
        <% if (title.includes('Limit')) { %>
          <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--text-primary);"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
        <% } else if (title.includes('Denied') || title.includes('Permission')) { %>
          <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--text-primary);"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        <% } else if (title.includes('Found')) { %>
          <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--text-muted);"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <% } else { %>
          <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--text-primary);"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
        <% } %>
      </div>

      <div class="form-header" style="margin-bottom: 1.5rem;">
        <h1 style="color: var(--text-primary); font-size: 2rem; font-weight: 800;"><%= title %></h1>
      </div>

      <p style="color: var(--text-secondary); margin-bottom: 2rem; line-height: 1.6; font-size: 1.05rem;">
        <%= message %>
      </p>

      <% if (typeof showDeviceReset !== 'undefined' && showDeviceReset) { %>
        <div class="alert alert-warning" style="text-align: left; font-size: 0.85rem; margin-bottom: 2rem; line-height: 1.5; display: flex; gap: 10px; align-items: flex-start; border-color: rgba(255, 255, 255, 0.05); background: rgba(255, 255, 255, 0.01);">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-warning); flex-shrink: 0; margin-top: 2px;"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
          <div>
            <strong>Why is this happening?</strong> To prevent account sharing, TeachSmart Academy restricts accounts to 1 concurrent device session. If you recently closed the browser without logging out, wait 5 minutes for it to expire automatically, or contact administration to reset your registered device fingerprint.
          </div>
        </div>
      <% } %>

      <div style="display: flex; justify-content: center; gap: 12px; flex-wrap: wrap;">
        <% if (user && user.userId) { %>
          <a href="/dashboard" class="btn btn-primary">Go to Dashboard</a>
          <a href="/logout" class="btn btn-secondary">Logout</a>
        <% } else { %>
          <a href="/" class="btn btn-primary">Go to Home</a>
          <a href="/login" class="btn btn-secondary">Login Page</a>
        <% } %>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
